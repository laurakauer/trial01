        "#PERGUNTA 1 - PERCENTUAL DE JOGOS PAGOS E GRATUITOS\n",
        "\n",
        "def calcular_percentual_gratuitos_pagos(jogos):\n",
        "    total_jogos = len(jogos)\n",
        "    gratuitos = 0\n",
        "    pagos = 0\n",
        "\n",
        "    for jogo in jogos:\n",
        "        if jogo.price == 0:\n",
        "            gratuitos += 1\n",
        "        else:\n",
        "            pagos += 1\n",
        "\n",
        "    percentual_gratuitos = (gratuitos / total_jogos) * 100\n",
        "    percentual_pagos = (pagos / total_jogos) * 100\n",
        "\n",
        "    return percentual_gratuitos, percentual_pagos\n",
        "\n",
        "\n",
        "percentual_gratuitos, percentual_pagos = calcular_percentual_gratuitos_pagos(jogos)\n",
        "\n",
        "print(\"Percentual de jogos gratuitos:\", round(percentual_gratuitos, 2), \"%\")\n",
        "print(\"Percentual de jogos pagos:\", round(percentual_pagos, 2), \"%\")"
