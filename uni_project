        "def extrair_ano(data):\n",
        "    partes = data.split(\",\")\n",
        "\n",
        "    if len(partes) < 2:\n",
        "        return None\n",
        "\n",
        "    ano_texto = partes[-1].strip()\n",
        "\n",
        "    if ano_texto.isdigit():\n",
        "        return int(ano_texto)\n",
        "\n",
        "    return None"
      ],
