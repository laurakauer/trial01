        "#PERGUNTA 3 - ANO COM MAIOR MÉDIA DE PREÇO DOS JOGOS PAGOS\n",
        "\n",
        "def ano_maior_media_preco(jogos):\n",
        "    soma_precos_ano = {}\n",
        "    quantidade_ano = {}\n",
        "\n",
        "    for jogo in jogos:\n",
        "        if jogo.price > 0:\n",
        "            ano = extrair_ano(jogo.release_date)\n",
        "\n",
        "            if ano is not None:\n",
        "                if ano in soma_precos_ano:\n",
        "                    soma_precos_ano[ano] += jogo.price\n",
        "                    quantidade_ano[ano] += 1\n",
        "                else:\n",
        "                    soma_precos_ano[ano] = jogo.price\n",
        "                    quantidade_ano[ano] = 1\n",
        "\n",
        "    medias_ano = {}\n",
        "\n",
        "    for ano in soma_precos_ano:\n",
        "        media = soma_precos_ano[ano] / quantidade_ano[ano]\n",
        "        medias_ano[ano] = media\n",
        "\n",
        "    maior_ano = None\n",
        "    maior_media = 0\n",
        "\n",
        "    for ano in medias_ano:\n",
        "        if medias_ano[ano] > maior_media:\n",
        "            maior_media = medias_ano[ano]\n",
        "            maior_ano = ano\n",
        "\n",
        "    return maior_ano, maior_media\n",
        "\n",
        "ano, media = ano_maior_media_preco(jogos)\n",
        "\n",
        "print(\"Ano com maior média de preço dos jogos pagos:\", ano)\n",
        "print(\"Média de preço:\", round(media, 2))\n"
      ],
