        "#PERGUNTA 2 - ANO COM MAIS JOGOS LANÇADOS\n",
        "\n",
        "def ano_com_mais_lancamentos(jogos):\n",
        "    contagem_anos = {}\n",
        "\n",
        "    for jogo in jogos:\n",
        "        ano = extrair_ano(jogo.release_date)\n",
        "\n",
        "        if ano is not None:\n",
        "            if ano in contagem_anos:\n",
        "                contagem_anos[ano] += 1\n",
        "            else:\n",
        "                contagem_anos[ano] = 1\n",
        "\n",
        "    maior_quantidade = max(contagem_anos.values())\n",
        "\n",
        "    anos_com_mais_lancamentos = []\n",
        "\n",
        "    for ano in contagem_anos:\n",
        "        if contagem_anos[ano] == maior_quantidade:\n",
        "            anos_com_mais_lancamentos.append(ano)\n",
        "\n",
        "    return anos_com_mais_lancamentos\n",
        "\n",
        "anos = ano_com_mais_lancamentos(jogos)\n",
        "\n",
